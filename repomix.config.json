{
    "output": {
        "filePath": "repomix/repomix-output.xml",
        "style": "xml"
    },
    "include": [
        "**/*.svelte",
        "**/*.ts",
        "**/*.html",
        "**/*.css",
        "**/*.json",
        "**/*.md",
        "**/*.yaml"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "repomix/repomix-output.xml",
            "node_modules/**",
            ".git/**",
            "dist/**",
            "build/**"
        ]
    }
}
