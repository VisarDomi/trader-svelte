{
    "output": {
        "filePath": "repomix/repomix-output.xml",
        "style": "xml"
    },
    "include": [
        "**/*.js",
        "**/*.jsx",
        "**/*.ts",
        "**/*.tsx",
        "**/*.html",
        "**/*.css",
        "**/*.scss",
        "**/*.json",
        "**/*.md",
        "**/Dockerfile",
        "**/*.yml",
        "netlify.toml"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "node_modules/**",
            ".git/**",
            "dist/**",
            "build/**",
            "coverage/**",
            "package-lock.json",
            "repomix/repomix-output.xml",
            "repomix.config.json",
            "nodemon.json",
            ".gitignore",
            "LICENSE",
            "temp.*",
            "responses/**"
        ]
    }
}
